: 1777749895:0;# 1. Installa gtklock dall'AUR\
paru -S gtklock\
\
# 2. Comando per bloccare lo schermo (da terminale o bind nel config di sway)\
gtklock
: 1777749929:0;paru -S gtklock-userinfo-module gtklock-powerbar-module gtklock-playerctl-module
: 1777749939:0;mkdir -p ~/.config/gtklock\
nano ~/.config/gtklock/style.css
: 1777749958:0;gtklock --css ~/.config/gtklock/style.css --modules userinfo powerbar
: 1777749970:0;# Definisci il comando\
set $lock_cmd gtklock --css ~/.config/gtklock/style.css --modules userinfo powerbar\
\
# Avvia il blocco allo standby\
exec swayidle -w \\
     timeout 300 '$lock_cmd' \\
     before-sleep '$lock_cmd'\
\
# Shortcut per bloccare manualmente (es: Mod + L)\
bindsym $mod+l exec $lock_cmd
: 1777750024:0;nano .config/sway/config
: 1777750055:0;sway reload
: 1777750089:0;# Avvio in debug senza fronzoli\
gtklock --verbose
: 1777750117:0;gtklock --help
: 1777750142:0;# 1. FIX ESSENZIALE: Permessi di sblocco (PAM)\
sudo cp /etc/pam.d/login /etc/pam.d/gtklock\
\
# 2. Crea la cartella di configurazione\
mkdir -p ~/.config/gtklock\
\
# 3. Crea il file di configurazione principale\
cat <<EOF > ~/.config/gtklock/config.ini\
[main]\
style=/home/mttbrbr/.config/gtklock/style.css\
modules=userinfo.so;powerbar.so;playerctl.so\
EOF\
\
# 4. Crea il file CSS (stile simil-greetd)\
cat <<EOF > ~/.config/gtklock/style.css\
window {\
    background-color: #1e1e2e;\
}\
\
#window-box {\
    background-color: rgba(45, 45, 70, 0.9);\
    border-radius: 12px;\
    padding: 50px;\
    margin: 300px;\
}\
\
input {\
    background: rgba(255, 255, 255, 0.1);\
    color: white;\
    border-radius: 8px;\
    padding: 10px;\
    border: 1px solid rgba(255, 255, 255, 0.2);\
}\
\
label {\
    color: white;\
    font-size: 1.2em;\
}\
EOF\
\
# 5. Avvia gtklock (leggerÃƒ€ automaticamente il config.ini)\
gtklock
