: 1777738327:0;mkdir -p ~/.config/waybar\
cat << 'EOF' > ~/.config/waybar/config\
{\
    "layer": "top",\
    "position": "top",\
    "height": 30,\
    "spacing": 4,\
    "modules-left": ["sway/workspaces", "sway/mode"],\
    "modules-center": ["clock"],\
    "modules-right": ["network", "cpu", "memory", "battery"],\
\
    "sway/workspaces": {\
        "disable-scroll": true,\
        "all-outputs": true,\
        "format": "{name}"\
    },\
    "clock": {\
        "format": "{:%H:%M  â€ƒ´  %d %b}",\
        "tooltip-format": "<big>{:%Y %B}</big>\n<tt><small>{calendar}</small></tt>"\
    },\
    "network": {\
        "format-wifi": "WIFI",\
        "format-ethernet": "ETH",\
        "format-disconnected": "DISCONNECTED"\
    },\
    "cpu": { "format": "CPU {usage}%" },\
    "memory": { "format": "RAM {used}GB" },\
    "battery": {\
        "format": "BAT {capacity}%",\
        "format-charging": "CHARGING {capacity}%"\
    }\
}\
EOF
: 1777738330:0;cat << 'EOF' > ~/.config/waybar/style.css\
* {\
    border: none;\
    border-radius: 0;\
    font-family: "Inter", "JetBrains Mono", "Helvetica", Arial;\
    font-size: 11px;\
    font-weight: 700;\
    text-transform: uppercase;\
}\
\
window#waybar {\
    background: transparent; /* Barra invisibile per effetto isole */\
}\
\
/* Stile per ogni modulo */\
#workspaces, #clock, #network, #cpu, #memory, #battery {\
    background: #1a1a1a;\
    color: #ffffff;\
    margin: 5px 2px;\
    padding: 0 15px;\
    border: 1px solid #333333;\
}\
\
/* Workspace attivo */\
#workspaces button.focused {\
    background: #ffffff;\
    color: #1a1a1a;\
}\
\
/* Workspace con finestre ma non attivo */\
#workspaces button {\
    color: #888888;\
}\
\
/* Orologio al centro piÃ¹ visibile */\
#clock {\
    border: 1px solid #ffffff;\
    font-weight: 900;\
}\
\
/* Batteria scarica in rosso */\
#battery.critical {\
    color: #ff5555;\
}\
EOF
