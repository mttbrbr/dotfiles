: 1777748320:0;# 1. Crea un backup di sicurezza\
cp ~/.config/foot/foot.ini ~/.config/foot/foot.ini.bak\
\
# 2. Cambia il font in Noto Sans Mono (monospace)\
sed -i 's/font=Noto Sans Regular/font=Noto Sans Mono/g' ~/.config/foot/foot.ini\
\
# 3. Commenta la vecchia riga del cursore che causa l'errore\
sed -i 's/^color=ffa560 f8f8f2/# &/' ~/.config/foot/foot.ini\
\
# 4. Aggiunge i colori corretti sotto la sezione [colors]\
sed -i '/^\[colors\]/a cursor=ffa560\ntext-cursor=f8f8f2' ~/.config/foot/foot.ini
: 1777748360:0;sed -i 's/^font=.*/font=monospace:size=11/' ~/.config/foot/foot.ini
