{
    "layer": "top",
    "position": "top",
    "height": 30,
    "modules-left": ["sway/workspaces"],
    "modules-center": ["clock"],
    "modules-right": ["network", "cpu", "memory", "battery"],

    "sway/workspaces": {
        "format": "{name}"
    },
    "clock": {
        "format": "{:%H:%M  —  %d %b}"
    },
    "network": {
        "format-wifi": "WIFI",
        "format-ethernet": "ETH",
        "format-disconnected": "DISCONNECTED"
    },
    "cpu": { 
        "format": "CPU {usage}%" 
    },
    "memory": { 
        "format": "RAM {used}GB" 
    },
    "battery": {
        "format": "BAT {capacity}%",
        "format-charging": "CHARGING {capacity}%"
    }
}
